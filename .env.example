# Shared
API_KEY=replace-this-with-a-long-random-value
HF_TOKEN=
PROFILE=auto

# This project always uses the full Qwen-Image-Edit-2511 base workflow.
# No Lightning LoRA or Turbo mode is attached.

# Logging and download progress
DOWNLOAD_LOG_INTERVAL_SECONDS=5
MODEL_DOWNLOAD_WORKERS=3
MODEL_DOWNLOAD_RETRIES=5
MODEL_DOWNLOAD_CHUNK_MB=8
UVICORN_LOG_LEVEL=info
APP_LOG_LEVEL=INFO

# Optional hardware overrides. Leave blank to let the container detect the GPU.
DEFAULT_CANDIDATES=
MAX_CANDIDATES=
LOCAL_GGUF_FILENAME=
COMFY_GPU_MODE=
COMFY_CACHE_LRU=
RESERVE_VRAM_GB=

ARG PYTORCH_IMAGE=pytorch/pytorch:2.7.1-cuda12.8-cudnn9-runtime
FROM ${PYTORCH_IMAGE}

ARG COMFYUI_REF=0d8b7510bdc5409f4a76c3191e122ddea50f4aa2
ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/workspace/cache/huggingface \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True,max_split_size_mb:512 \
    COMFYUI_DIR=/opt/ComfyUI \
    APP_DIR=/opt/qwen-worker \
    DATA_DIR=/workspace

RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl ca-certificates ffmpeg libgl1 libglib2.0-0 tini \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/Comfy-Org/ComfyUI.git /opt/ComfyUI \
    && cd /opt/ComfyUI \
    && git checkout "${COMFYUI_REF}" \
    && pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir \
         fastapi==0.115.12 uvicorn[standard]==0.34.3 httpx==0.28.1 \
         python-multipart==0.0.20 pydantic-settings==2.9.1

# Included in the cloud image too, so PROFILE=auto can fall back to GGUF
# when the same container is started on a smaller GPU.
RUN git clone https://github.com/city96/ComfyUI-GGUF.git /opt/ComfyUI/custom_nodes/ComfyUI-GGUF \
    && pip install --no-cache-dir -r /opt/ComfyUI/custom_nodes/ComfyUI-GGUF/requirements.txt \
    && pip check \
    && python - <<'PY'
import huggingface_hub
import transformers
from transformers import CLIPTokenizer
print(f"dependency-smoke-test transformers={transformers.__version__} huggingface_hub={huggingface_hub.__version__}")
print(f"clip-tokenizer-import={CLIPTokenizer.__name__}")
PY

WORKDIR /opt/qwen-worker
COPY app ./app
COPY scripts ./scripts
COPY workflows ./workflows
COPY tools ./tools
COPY README.md LICENSE ./
RUN chmod +x scripts/*.sh \
    && bash -n scripts/entrypoint.sh \
    && python -m py_compile app/main.py scripts/bootstrap_models.py scripts/detect_hardware.py \
    && ! grep -Fq -- '--normalvram' scripts/entrypoint.sh \
    && cd /opt/ComfyUI \
    && python main.py --help >/tmp/comfy-help.txt \
    && grep -Fq -- '--reserve-vram' /tmp/comfy-help.txt \
    && grep -Fq -- '--gpu-only' /tmp/comfy-help.txt

EXPOSE 8000
ENTRYPOINT ["/usr/bin/tini", "--", "/opt/qwen-worker/scripts/entrypoint.sh"]
